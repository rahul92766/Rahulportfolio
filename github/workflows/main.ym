yaml name: Deploy to GitHub Pages on: push: branches: - main # Ya aapki default branch ka naam jobs: build-and-deploy: runs-on: ubuntu-latest steps: - name: Checkout Repository uses: actions/checkout@v3 - name: Setup Node.js uses: actions/setup-node@v3 with: node-version: 18 # Ya jo version aap use karte hain - name: Install Dependencies run: npm install - name: Build Project run: npm run build # Aapki build command - name: Deploy to GitHub Pages uses: JamesIves/github-pages-deploy-action@v4 with: folder: build # Jahan index.htm
